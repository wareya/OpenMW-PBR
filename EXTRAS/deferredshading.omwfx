sampler_2d dfg {
    source = "shaders/textures/dfg.png";
    mag_filter = nearest;
    min_filter = nearest;
}

uniform_bool uDisable {
    default = false;
    description = "...";
    display_name = "uDisable";
}
uniform_bool uContactShadow {
    default = true;
    description = "...";
    display_name = "uContactShadow";
}
uniform_bool uBloom {
    default = true;
    description = "...";
    display_name = "uBloom";
}
uniform_bool uNoExposureHDR {
    default = false;
    description = "...";
    display_name = "uNoExposureHDR";
}
uniform_bool uLazyDiffuse3 {
    default = false;
    description = "Outdated variant of Lazy Diffuse 2 that got rid of the smooth fresnel effect. Believe it or not, this is unrealistic. Looks a lot like FON.";
    display_name = "uLazyDiffuse3";
}
uniform_bool uLazyDiffuse2 {
    default = true;
    description = "Custom variant of Hammon that's fitted to different data and looks more realistic (more like oren-nayar) on very rough objects.";
    display_name = "uLazyDiffuse2 (recommended)";
}
uniform_bool uLazyDiffuse {
    default = false;
    description = "Cheap approximation of Hammon Diffuse.";
    display_name = "uLazyDiffuse";
}
uniform_bool uHammonDiffuse {
    default = false;
    description = "Hammon's diffuse term, described at the relevant GDC talk. Unfortunately slightly under-estimates how bright very rough objects should be when the camera and sun are both looking straight at them.";
    display_name = "uHammonDiffuse";
}
uniform_bool uFujiOrenNayar {
    default = false;
    description = "Also called FON. The final version of Fuji's Oren-Nayar approximation. Unfortunately Oren-Nayar is not fully physically realistic (it fails to take exit fresnel effects into account, and it's based on a non-GGX, i.e. unrealistic, microfacet distribution).";
    display_name = "uFujiOrenNayarDiffuse";
}
uniform_bool uSpecularAoHack {
    default = true;
    description = "A form of specular AO occlusion that interprets AO as macro V-cavity closedness + extinguishes specularity based on view angle and light angle if not dead-on.";
    display_name = "uSpecularAoHack";
}
uniform_bool uSSAO {
    default = true;
    description = "Not what you expect from SSAO: only affects ambient lighting, not direct lights or emissives.";
    display_name = "uSSAO";
}
uniform_bool uFakeSSS {
    default = true;
    description = "Fake SSS that glows up on tangents. Extinguished by shadows.";
    display_name = "uFakeSSS";
}
uniform_bool uFakeSSSForce {
    default = true;
    description = "Force SSS on everything, even if there's no PBR SSS data.";
    display_name = "uFakeSSSForce";
}
uniform_bool uBasicAmbientLight {
    default = false;
    description = "Replace integrated BRDF ambient light with basically-flat ambient light. Looks less natural but more intuitive.";
    display_name = "uBasicAmbientLight";
}
uniform_bool uNoRaycastMetallics {
    default = false;
    description = "Use a cheap approximation for metallics instead of raycasting. Turning this option on disables raycasting for them and makes them cheaper.";
    display_name = "uNoRaycastMetallics";
}
uniform_bool uNoPBR {
    default = false;
    description = "...";
    display_name = "uNoPBR";
}
uniform_bool uAccurateSRGB {
    default = false;
    description = "Discouraged because some morrowind assets (e.g. night sky) were designed for 2.2 gamma CRTs and look bad if the bottom of the gamma curve is linear.";
    display_name = "uAccurateSRGB (discouraged)";
}
uniform_float uContactShadowThickness {
    default = 20.0;
    min = 0.0;
    max = 500.0;
    step = 2.5;
    description = "....";
    display_name = "uContactShadowThickness";
}

